<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Lookout.Views.ChatView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:Lookout.Views"
    xmlns:vm="using:Lookout.ViewModels"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- API key entry -->
        <Border x:Name="ApiKeyBar" Grid.Row="0" Visibility="Collapsed"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1" Padding="12,10">
            <StackPanel Spacing="6">
                <TextBlock Text="{x:Bind ViewModel.KeyPrompt, Mode=OneWay}"
                           FontSize="12" TextWrapping="Wrap" />
                <Grid ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="ApiKeyBox" Grid.Column="0"
                                 PlaceholderText="{x:Bind ViewModel.KeyPlaceholder, Mode=OneWay}" />
                    <Button x:Name="SaveKeyButton" Grid.Column="1" Content="Save"
                            Click="OnSaveKeyClick" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Messages -->
        <ListView x:Name="MessageList" Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.Messages}"
                  SelectionMode="None"
                  HorizontalContentAlignment="Stretch"
                  Padding="0,8">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="MinHeight" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:MessageViewModel">
                    <views:MessageView />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Empty-state hint (shown before the first message) -->
        <StackPanel x:Name="EmptyHint" Grid.Row="1" Padding="24"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Spacing="8" MaxWidth="300">
            <TextBlock Text="👁" FontSize="34" HorizontalAlignment="Center" />
            <TextBlock Text="Lookout can see your screen and help."
                       TextWrapping="Wrap" TextAlignment="Center" FontSize="14" />
            <TextBlock Text="Ask a question below to start."
                       TextWrapping="Wrap" TextAlignment="Center" Opacity="0.7" FontSize="13" />
            <TextBlock Text="Tip: press Ctrl+Alt+L anytime to show or hide this window."
                       TextWrapping="Wrap" TextAlignment="Center" Opacity="0.55" FontSize="12"
                       Margin="0,8,0,0" />
        </StackPanel>

        <!-- Status line -->
        <TextBlock x:Name="StatusLine" Grid.Row="2" Margin="12,2"
                   FontSize="12" Opacity="0.7" TextWrapping="Wrap"
                   Visibility="Collapsed" />

        <!-- Input -->
        <Grid Grid.Row="3" Padding="12,8" ColumnSpacing="6"
              Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="InputBox" Grid.Column="0"
                     PlaceholderText="Ask Lookout…"
                     Text="{x:Bind ViewModel.InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="False"
                     KeyDown="OnInputKeyDown" />
            <Button x:Name="SendButton" Grid.Column="1"
                    Content="Send" Style="{ThemeResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.SendCommand}" />
            <Button x:Name="StopButton" Grid.Column="1"
                    Content="Stop" Visibility="Collapsed"
                    Command="{x:Bind ViewModel.CancelCommand}" />
        </Grid>
    </Grid>
</UserControl>

<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Lookout.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <StackPanel Padding="22" Spacing="20" MaxWidth="480" HorizontalAlignment="Left">
            <TextBlock Text="Lookout Settings" FontSize="20" FontWeight="SemiBold" />

            <!-- AI provider -->
            <StackPanel Spacing="6">
                <TextBlock Text="AI provider" FontWeight="SemiBold" />
                <ComboBox x:Name="ProviderBox" HorizontalAlignment="Stretch"
                          SelectionChanged="OnProviderChanged">
                    <ComboBoxItem Content="Anthropic (direct)" Tag="Anthropic" />
                    <ComboBoxItem Content="Google Gemini (direct)" Tag="Google" />
                    <ComboBoxItem Content="OpenRouter (GLM, GPT, …)" Tag="OpenRouter" />
                </ComboBox>

                <TextBlock Text="Model" FontSize="12" Opacity="0.7" Margin="0,4,0,0" />
                <TextBox x:Name="ModelBox" />
                <TextBlock x:Name="ModelHint" FontSize="11" Opacity="0.6" TextWrapping="Wrap" />

                <StackPanel x:Name="BaseUrlPanel" Spacing="4" Visibility="Collapsed">
                    <TextBlock Text="API base URL" FontSize="12" Opacity="0.7" Margin="0,4,0,0" />
                    <TextBox x:Name="BaseUrlBox" />
                </StackPanel>
            </StackPanel>

            <!-- API key -->
            <StackPanel Spacing="6">
                <TextBlock x:Name="KeyHeader" Text="API key" FontWeight="SemiBold" />
                <TextBlock x:Name="KeyStatus" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                <PasswordBox x:Name="ApiKeyBox" PlaceholderText="sk-ant-..." />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="SaveKeyButton" Content="Save key"
                            Style="{ThemeResource AccentButtonStyle}" Click="OnSaveKey" />
                    <Button x:Name="RemoveKeyButton" Content="Remove key" Click="OnRemoveKey" />
                </StackPanel>
            </StackPanel>

            <!-- Personalization -->
            <StackPanel Spacing="6">
                <TextBlock Text="Personalization" FontWeight="SemiBold" />
                <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.7"
                           Text="Tell Lookout about yourself — your name, what you use this computer for, your comfort level with technology. This is shared at the start of every conversation." />
                <Button Content="Open context file" Click="OnOpenContext" />
            </StackPanel>

            <!-- Memory -->
            <StackPanel Spacing="6">
                <TextBlock Text="Memory" FontWeight="SemiBold" />
                <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.7"
                           Text="Lookout saves short notes about you across sessions so it can help better over time." />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Open notes file" Click="OnOpenNotes" />
                    <Button Content="Clear saved notes" Click="OnClearNotes" />
                </StackPanel>
                <TextBlock x:Name="MemoryStatus" FontSize="12" Opacity="0.7" />
            </StackPanel>

            <TextBlock x:Name="FolderPath" FontSize="11" Opacity="0.5" TextWrapping="Wrap" />

            <Button x:Name="CloseButton" Content="Close" Click="OnClose"
                    HorizontalAlignment="Right" MinWidth="90" Margin="0,4,0,0" />
        </StackPanel>
    </ScrollViewer>
</Window>
